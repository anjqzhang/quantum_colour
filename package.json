{
  "name": "quantum-colour",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm build && XDG_CONFIG_HOME=.wrangler/config wrangler pages dev dist --compatibility-date=2026-05-13 --inspector-port=0 --persist-to=.wrangler/state",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:app": "pnpm build && wrangler pages deploy dist",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.90.1"
  }
}
